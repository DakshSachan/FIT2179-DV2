{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 300,
  "title": "Total Café Establishments by Neighborhood",
  "data": {
    "url": "https://data.melbourne.vic.gov.au/api/explore/v2.1/catalog/datasets/cafes-and-restaurants-with-seating-capacity/records?limit=100",
    "format": {
      "type": "json",
      "property": "results"
    }
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "clue_small_area",
      "type": "nominal",
      "title": "Neighborhood Area",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Cafés"
    },
    "color": {"value": "#a0522d"},
    "tooltip": [
      {"field": "clue_small_area", "type": "nominal", "title": "Area"},
      {"aggregate": "count", "type": "quantitative", "title": "Total Cafés"}
    ]
  }
}
