{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Total Café Establishments by Neighborhood",
  "data": {
    "url": "https://data.melbourne.vic.gov.au/api/v2/catalog/datasets/cafes-and-restaurants-with-seating-capacity/exports/json",
    "format": {"type": "json"}
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "clue_small_area",
      "type": "nominal",
      "title": "Neighborhood Area",
      "sort": "-y",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Cafés"
    },
    "color": {
      "value": "#a0522d"
    },
    "tooltip": [
      {"field": "clue_small_area", "type": "nominal", "title": "Area"},
      {"aggregate": "count", "type": "quantitative", "title": "Total Cafés"}
    ]
  }
}
