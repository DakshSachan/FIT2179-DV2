{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "cafes-and-restaurants-with-seating-capacity.csv"},
  "width": 950,
  "height": 400,
  "title": "Total Seating Capacities Across Commercial Suburbs",
  "mark": {"type": "bar", "color": "#6F4E37", "cornerRadiusEnd": 4},
  "encoding": {
    "x": {
      "field": "CLUE small area",
      "type": "nominal",
      "axis": {"labelAngle": -30},
      "title": "Suburbs"
    },
    "y": {
      "field": "Number of seats",
      "type": "quantitative",
      "aggregate": "sum",
      "title": "Total Seating Capacity"
    },
    "tooltip": [
      {"field": "CLUE small area", "type": "nominal", "title": "Suburb"},
      {"field": "Number of seats", "type": "quantitative", "aggregate": "sum", "title": "Total Seats"}
    ]
  }
}
