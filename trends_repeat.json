{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv",
    "format": {"maxrows": 100000}
  },
  "title": "Distribution Profile of Seat Densities Across Melbourne",
  "width": "container",
  "height": 300,
  "mark": {"type": "bar", "color": "#D2B48C"},
  "encoding": {
    "x": {
      "field": "Number of seats", 
      "type": "quantitative", 
      "bin": {"maxbins": 30}, 
      "title": "Number of Seats per Venue"
    },
    "y": {
      "aggregate": "count", 
      "type": "quantitative", 
      "title": "Number of Establishments"
    },
    "color": {
      "field": "CLUE small area", 
      "type": "nominal", 
      "title": "Area",
      "scale": {"scheme": "tableau10"}
    }
  }
}
