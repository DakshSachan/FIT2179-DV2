{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv",
    "format": {"maxrows": 50000}
  },
  "title": "Seating Capacity Distributions Across Suburbs",
  "width": 800,
  "height": 350,
  "transform": [
    {"filter": "datum['Number of seats'] > 0 && datum['Number of seats'] <= 300"}
  ],
  "mark": {
    "type": "boxplot",
    "extent": "min-max",
    "size": 30,
    "ticks": true
  },
  "encoding": {
    "x": {
      "field": "CLUE small area",
      "type": "nominal",
      "title": "Melbourne Suburb Area",
      "axis": {"labelAngle": -20}
    },
    "y": {
      "field": "Number of seats",
      "type": "quantitative",
      "title": "Number of Seats per Venue"
    },
    "color": {
      "field": "CLUE small area",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": ["Melbourne (CBD)", "Carlton", "Docklands", "North Melbourne", "Southbank", "West Melbourne (Residential)"],
        "range": ["#4A2E1B", "#6F4E37", "#A67B5B", "#C19A6B", "#D2B48C", "#E1D3C1"]
      }
    }
  }
}
