{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv",
    "format": {"maxrows": 50000}
  },
  "title": "Seating Density Profile Across Key Areas",
  "width": 800,
  "height": 300,
  "transform": [
    {"filter": "datum['Number of seats'] > 0 && datum['Number of seats'] <= 300"}
  ],
  "mark": {"type": "area", "opacity": 0.4, "interpolate": "monotone"},
  "encoding": {
    "x": {
      "field": "Number of seats",
      "type": "quantitative",
      "title": "Seat Capacity (Venues capped at 300 seats)"
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Density of Establishments Plot"
    },
    "color": {
      "field": "CLUE small area",
      "type": "nominal",
      "title": "Melbourne Suburb Area",
      "scale": {
        "domain": ["Melbourne (CBD)", "Carlton", "Docklands", "North Melbourne", "Southbank", "West Melbourne (Residential)"],
        "range": ["#4A2E1B", "#6F4E37", "#A67B5B", "#C19A6B", "#D2B48C", "#E8D8C8"]
      }
    }
  }
}
