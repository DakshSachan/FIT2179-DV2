{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Indoor and Outdoor Seating Distribution",

  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv"
  },

  "mark": {
    "type": "arc",
    "innerRadius": 60
  },

  "width": 450,
  "height": 450,

  "encoding": {

    "theta": {
      "aggregate": "sum",
      "field": "Number of seats",
      "type": "quantitative"
    },

    "color": {
      "field": "Seating type",
      "type": "nominal",
      "scale": {
        "range": [
          "#6F4E37",
          "#D2B48C"
        ]
      }
    },

    "tooltip": [
      {
        "field": "Seating type"
      },
      {
        "aggregate": "sum",
        "field": "Number of seats",
        "title": "Total Seats"
      }
    ]
  }
}
