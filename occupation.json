{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "Occupation-Table 1.csv"
  },

  "transform": [
    {
      "fold": [
        "Professionals",
        "Managers",
        "Clerical/Admin",
        "Community/Personal Service",
        "Technicians/Trades",
        "Sales",
        "Labourers",
        "Machinery Operators"
      ],
      "as": ["Occupation", "Percentage"]
    }
  ],

  "mark": "bar",

  "width": 400,
  "height": 400,

  "title": "Occupational Composition Across Melbourne Postcodes",

  "encoding": {

    "x": {
      "field": "Postcode",
      "type": "nominal"
    },

    "y": {
      "field": "Percentage",
      "type": "quantitative",
      "stack": "normalize"
    },

    "color": {
      "field": "Occupation",
      "type": "nominal",
      "scale": {
        "range": [
          "#4A2E1B",
          "#6F4E37",
          "#8B5E3C",
          "#A67C52",
          "#C19A6B",
          "#D2B48C",
          "#7B4F35",
          "#B08968"
        ]
      }
    },

    "tooltip": [
      {
        "field": "Postcode"
      },
      {
        "field": "Occupation"
      },
      {
        "field": "Percentage"
      }
    ]
  }
}
