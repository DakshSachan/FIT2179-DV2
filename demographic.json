{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "ABS Census Demographic Context by Region",
  "vconcat": [
    {
      "title": "Economic Profile: Median Weekly Income",
      "data": {"url": "Income-Table 1.csv"},
      "width": 800,
      "height": 180,
      "mark": {"type": "bar", "color": "#4A2E1B", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "title": "Postcode"},
        "y": {"field": "Household Weekly Income", "type": "quantitative", "title": "Income ($/week)"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal"},
          {"field": "Household Weekly Income", "type": "quantitative", "title": "Avg Income"}
        ]
      }
    },
    {
      "title": "Social Profile: White-Collar Professional Concentration (%)",
      "data": {"url": "Occupation-Table 1.csv"},
      "width": 800,
      "height": 180,
      "mark": {"type": "bar", "color": "#A67B5B", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "title": "Postcode"},
        "y": {"field": "Professionals", "type": "quantitative", "title": "% Professionals"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal"},
          {"field": "Professionals", "type": "quantitative"}
        ]
      }
    }
  ]
}
