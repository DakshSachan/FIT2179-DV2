{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "ABS Census Demographic Context by Postcode",
  "vconcat": [
    {
      "title": "Economic Profile: Household Weekly Income",
      "data": {"url": "Income-Table 1.csv"},
      "width": 550,
      "height": 180,
      "mark": {"type": "bar", "color": "#6F4E37", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "axis": {"labelAngle": 0}, "title": "Postcode"},
        "y": {"field": "Household Weekly Income", "type": "quantitative", "title": "Income ($/week)"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal", "title": "Postcode"},
          {"field": "Household Weekly Income", "type": "quantitative", "title": "Weekly Household Income"}
        ]
      }
    },
    {
      "title": "Social Profile: Professionals Distribution (%)",
      "data": {"url": "Occupation-Table 1.csv"},
      "width": 550,
      "height": 180,
      "mark": {"type": "bar", "color": "#C19A6B", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "axis": {"labelAngle": 0}, "title": "Postcode"},
        "y": {"field": "Professionals", "type": "quantitative", "title": "% of White-Collar Professionals"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal", "title": "Postcode"},
          {"field": "Professionals", "type": "quantitative", "title": "Professionals %"}
        ]
      }
    }
  ],
  "config": {
    "axis": {"labelFont": "sans-serif", "titleFont": "sans-serif"},
    "title": {"font": "sans-serif", "fontSize": 14}
  }
}
