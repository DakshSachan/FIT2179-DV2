{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "ABS Census Demographic Context by Postcode",
  "vconcat": [
    {
      "title": "Economic Profile: Household Weekly Income",
      "data": {"url": "Income-Table 1.csv"},
      "width": 950,
      "height": 200,
      "mark": {"type": "bar", "color": "#6F4E37", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "title": "Postcode"},
        "y": {"field": "Household Weekly Income", "type": "quantitative", "title": "Income ($/week)"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal"},
          {"field": "Household Weekly Income", "type": "quantitative"}
        ]
      }
    },
    {
      "title": "Social Profile: Professionals Distribution (%)",
      "data": {"url": "Occupation-Table 1.csv"},
      "width": 950,
      "height": 200,
      "mark": {"type": "bar", "color": "#C19A6B", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {"field": "Postcode", "type": "nominal", "title": "Postcode"},
        "y": {"field": "Professionals", "type": "quantitative", "title": "% of White-Collar Professionals"},
        "tooltip": [
          {"field": "Postcode", "type": "nominal"},
          {"field": "Professionals", "type": "quantitative"}
        ]
      }
    }
  ]
}
