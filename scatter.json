{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 350,
  "title": "Seating Capacities across Neighborhoods",
  "data": {
    "url": "https://data.melbourne.vic.gov.au/api/explore/v2.1/catalog/datasets/cafes-and-restaurants-with-seating-capacity/records?limit=100",
    "format": {
      "type": "json",
      "property": "results"
    }
  },
  "mark": {"type": "point", "filled": true, "size": 60},
  "encoding": {
    "x": {
      "field": "number_of_seats",
      "type": "quantitative",
      "title": "Number of Seats"
    },
    "y": {
      "field": "clue_small_area",
      "type": "nominal",
      "title": "Neighborhood"
    },
    "color": {
      "field": "seating_type",
      "type": "nominal",
      "title": "Seating Type"
    },
    "tooltip": [
      {"field": "trading_name", "type": "nominal", "title": "Café Name"},
      {"field": "number_of_seats", "type": "quantitative", "title": "Seats"},
      {"field": "seating_type", "type": "nominal", "title": "Type"}
    ]
  }
}
