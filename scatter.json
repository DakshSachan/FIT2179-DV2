{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "cafes-and-restaurants-with-seating-capacity.csv"},
  "width": 950,
  "height": 400,
  "title": "Establishment Densities by Block Coordinates",
  "mark": {"type": "point", "filled": true, "size": 60, "opacity": 0.6, "color": "#C19A6B"},
  "encoding": {
    "x": {"field": "Block ID", "type": "quantitative", "title": "City Block Reference Identifier"},
    "y": {"field": "Number of seats", "type": "quantitative", "title": "Seats per Venue"},
    "color": {"field": "Seating type", "type": "nominal", "title": "Seating Type"},
    "tooltip": [
      {"field": "Trading name", "type": "nominal", "title": "Venue"},
      {"field": "Block ID", "type": "quantitative", "title": "Block"},
      {"field": "Number of seats", "type": "quantitative", "title": "Seats"}
    ]
  }
}
