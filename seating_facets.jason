{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "cafes-and-restaurants-with-seating-capacity.csv"},
  "title": "Seating Capacities and Types Across Melbourne Neighborhoods",
  "facet": {
    "field": "CLUE small area",
    "type": "nominal",
    "columns": 3,
    "title": "Suburbs"
  },
  "spec": {
    "width": 180,
    "height": 130,
    "mark": {"type": "bar", "color": "#6F4E37"},
    "encoding": {
      "x": {
        "field": "Seating type",
        "type": "nominal",
        "title": "Seating Type"
      },
      "y": {
        "field": "Number of seats",
        "type": "quantitative",
        "aggregate": "sum",
        "title": "Total Capacity"
      },
      "tooltip": [
        {"field": "CLUE small area", "type": "nominal"},
        {"field": "Seating type", "type": "nominal"},
        {"field": "Number of seats", "type": "quantitative", "aggregate": "sum", "title": "Total Seats"}
      ]
    }
  }
}
