{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv"
  },

  "transform": [
    {
      "filter": "datum['Census year'] == 2024"
    }
  ],

  "width": 700,
  "height": 350,

  "title": "Number of Distinct Hospitality Venues by Suburb (2024)",

  "mark": {
    "type": "bar",
    "color": "#8B5E3C"
  },

  "encoding": {

    "y": {
      "field": "CLUE small area",
      "type": "nominal",
      "sort": "-x",
      "title": "Suburb"
    },

    "x": {
      "aggregate": "distinct",
      "field": "Trading name",
      "type": "quantitative",
      "title": "Distinct Venues"
    },

    "tooltip": [
      {
        "field": "CLUE small area",
        "title": "Suburb"
      },
      {
        "aggregate": "distinct",
        "field": "Trading name",
        "title": "Distinct Venues"
      }
    ]
  }
}
