{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "cafes-and-restaurants-with-seating-capacity.csv"
  },

  "width": 700,
  "height": 350,

  "title": "Number of Café Records by Suburb",

  "mark": {
    "type": "bar",
    "color": "#8B5E3C"
  },

  "encoding": {
    "y": {
      "field": "CLUE small area",
      "type": "nominal",
      "sort": "-x",
      "title": "Suburb"
    },

    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Records"
    },

    "tooltip": [
      {
        "field": "CLUE small area",
        "title": "Suburb"
      },
      {
        "aggregate": "count",
        "title": "Records"
      }
    ]
  }
}
