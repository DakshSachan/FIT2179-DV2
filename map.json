{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": "Geographic Distribution of Melbourne Cafés",
  "layer": [
    {
      "data": {
        "url": "clue_map.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "projection": {"type": "mercator"},
      "mark": {
        "type": "geoshape",
        "fill": "#f9f6f0",
        "stroke": "#d4d4d1",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "cafes_data.csv"
      },
      "projection": {"type": "mercator"},
      "mark": {"type": "circle", "opacity": 0.7, "cursor": "pointer"},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "size": {
          "field": "total_number_of_seats",
          "type": "quantitative",
          "title": "Total Seats",
          "scale": {"range": [10, 300]}
        },
        "color": {
          "field": "clue_small_area",
          "type": "nominal",
          "title": "Area",
          "scale": {"scheme": "tableau10"}
        },
        "tooltip": [
          {"field": "trading_name", "type": "nominal", "title": "Café Name"},
          {"field": "clue_small_area", "type": "nominal", "title": "Area"},
          {"field": "total_number_of_seats", "type": "quantitative", "title": "Seats"}
        ]
      }
    }
  ]
}
