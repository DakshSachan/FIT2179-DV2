{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": "Geographic Clustering of Melbourne Cafés",
  "data": {
    "url": "https://data.melbourne.vic.gov.au/api/v2/catalog/datasets/cafes-and-restaurants-with-seating-capacity/exports/json",
    "format": {"type": "json"}
  },
  "mark": {"type": "circle", "size": 12, "opacity": 0.5, "color": "#8b5a2b"},
  "encoding": {
    "x": {
      "field": "longitude",
      "type": "quantitative",
      "scale": {"zero": false},
      "title": "Longitude"
    },
    "y": {
      "field": "latitude",
      "type": "quantitative",
      "scale": {"zero": false},
      "title": "Latitude"
    },
    "tooltip": [
      {"field": "trading_name", "type": "nominal", "title": "Café Name"},
      {"field": "clue_small_area", "type": "nominal", "title": "Area"}
    ]
  }
}
