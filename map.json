{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 400,
  "title": "Geographic Clustering of Melbourne Cafés",
  "data": {
    "url": "https://data.melbourne.vic.gov.au/api/explore/v2.1/catalog/datasets/cafes-and-restaurants-with-seating-capacity/records?limit=100",
    "format": {
      "type": "json",
      "property": "results"
    }
  },
  "mark": {"type": "circle", "size": 30, "opacity": 0.7, "color": "#8b5a2b"},
  "encoding": {
    "x": {
      "field": "longitude",
      "type": "quantitative",
      "scale": {"domain": [144.9, 145.0]},
      "title": "Longitude"
    },
    "y": {
      "field": "latitude",
      "type": "quantitative",
      "scale": {"domain": [-37.85, -37.75]},
      "title": "Latitude"
    },
    "tooltip": [
      {"field": "trading_name", "type": "nominal", "title": "Café Name"},
      {"field": "clue_small_area", "type": "nominal", "title": "Area"}
    ]
  }
}
