{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 450,
  "title": "Geographic Distribution of Melbourne Cafés",
  "layer": [
    {
      "data": {
        "url": "small-areas-for-census-of-land-use-and-employment-clue.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "projection": {"type": "mercator"},
      "mark": {
        "type": "geoshape",
        "fill": "#fcfaf2",
        "stroke": "#cbcac4",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "url": "cafes_data.csv"
      },
      "projection": {"type": "mercator"},
      "mark": {
        "type": "circle", 
        "opacity": 0.75, 
        "size": 40, 
        "color": "#6F4E37",
        "cursor": "pointer"
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "tooltip": [
          {"field": "trading_name", "type": "nominal", "title": "Café Name"},
          {"field": "clue_small_area", "type": "nominal", "title": "Area"}
        ]
      }
    }
  ]
}
