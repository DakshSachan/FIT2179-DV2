{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 950,
  "height": 550,
  "title": {
    "text": "Geographic Distribution of Melbourne Cafés",
    "fontSize": 16,
    "font": "sans-serif"
  },
  "projection": {
    "type": "mercator",
    "center": [144.9631, -37.8136],
    "scale": 200000
  },
  "layer": [
    {
      "data": {
        "url": "small-areas-for-census-of-land-use-and-employment-clue.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#fcfaf2",
        "stroke": "#cbcac4",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "url": "cafes-and-restaurants-with-seating-capacity.csv"
      },
      "mark": {
        "type": "circle", 
        "opacity": 0.6, 
        "size": 60, 
        "color": "#6F4E37",
        "cursor": "pointer"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "tooltip": [
          {"field": "Trading name", "type": "nominal", "title": "Café Name"},
          {"field": "CLUE small area", "type": "nominal", "title": "Area"},
          {"field": "Seating type", "type": "nominal", "title": "Type"},
          {"field": "Number of seats", "type": "quantitative", "title": "Seats"}
        ]
      }
    }
  ]
}
