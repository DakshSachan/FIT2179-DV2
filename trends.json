{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "cafes-and-restaurants-with-seating-capacity.csv"},
  "title": "Distribution Profile of Seat Densities",
  "width": 650,
  "height": 250,
  "mark": {"type": "bar", "color": "#C19A6B"},
  "encoding": {
    "x": {
      "field": "Number of seats", 
      "type": "quantitative", 
      "bin": {"maxbins": 30}, 
      "title": "Number of Seats per Venue"
    },
    "y": {
      "aggregate": "count", 
      "type": "quantitative", 
      "title": "Number of Establishments"
    },
    "color": {
      "field": "CLUE small area", 
      "type": "nominal", 
      "title": "Area",
      "scale": {"scheme": "tableau10"}
    }
  }
}
