{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Leading Industry Share by Postcode",

  "data": {
    "url": "Industry-Table 1.csv"
  },

  "width": 400,
  "height": 400,

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },

  "encoding": {

    "y": {
      "field": "Postcode",
      "type": "nominal",
      "sort": "-x",
      "title": "Postcode"
    },

    "x": {
      "field": "%",
      "type": "quantitative",
      "title": "Leading Industry Share (%)"
    },

    "color": {
      "field": "Top Industry 1",
      "type": "nominal",
      "scale": {
        "range": [
          "#4A2E1B",
          "#6F4E37",
          "#8B5E3C",
          "#A67C52",
          "#C19A6B",
          "#D2B48C"
        ]
      }
    },

    "tooltip": [
      {"field": "Postcode"},
      {"field": "Top Industry 1"},
      {"field": "%"}
    ]
  }
}
