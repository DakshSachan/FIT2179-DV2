{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "incomeCafe.csv"
  },
  "width" : 650,
  "height" : 450,

  "transform": [
    {
      "calculate": "toNumber(datum['Household Weekly Income'])",
      "as": "Income"
    },
    {
      "calculate": "toNumber(datum['Cafe count'])",
      "as": "Cafes"
    }
  ],

  "layer": [
  {
    "mark": {
      "type": "point",
      "filled": true,
      "size": 250,
      "color": "#6F4E37"
    }
  },
  {
    "mark": {
      "type": "text",
      "dx": 10,
      "dy": -10,
      "fontSize": 11,
      "color": "#4A2E1B"
    },
    "encoding": {
      "text": {
        "field": "Suburb"
      }
    }
  }
],
  
  "encoding": {
    "x": {
      "field": "Income",
      "type": "quantitative",
      "title": "Median Household Weekly Income ($)"
    },

    "y": {
      "field": "Cafes",
      "type": "quantitative",
      "title": "Distinct Hospitality Venues"
    },

    "tooltip": [
      {"field": "Suburb"},
      {"field": "Income"},
      {"field": "Cafes"}
    ]
  }
}
