{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Income versus Hospitality Activity",

  "data": {
    "url": "incomeVScafe.csv"
  },

  "width": 650,
  "height": 400,

  "mark": {
    "type": "point",
    "filled": true,
    "size": 250,
    "color": "#6F4E37"
  },

  "encoding": {

    "x": {
      "field": "Household Weekly Income",
      "type": "quantitative",
      "title": "Median Household Weekly Income ($)"
  },

    "y": {
      "field": "Cafe count",
      "type": "quantitative",
      "title": "Distinct Hospitality Venues"
  }

    "tooltip": [
      {"field": "Suburb"},
      {"field": "Household Weekly Income", "title": "Income"},
      {"field": "Cafe count", "title": "Venue Count"}
    ]
  }
}
