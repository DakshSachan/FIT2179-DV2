{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "incomeCafe.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum['Household Weekly Income'])",
      "as": "Income"
    },
    {
      "calculate": "toNumber(datum['Cafe count'])",
      "as": "Cafes"
    }
  ],

  "mark": {
    "type": "point",
    "filled": true,
    "size": 250,
    "color": "#6F4E37"
  },

  "encoding": {
    "x": {
      "field": "Income",
      "type": "quantitative",
      "title": "Median Household Weekly Income ($)"
    },

    "y": {
      "field": "Cafes",
      "type": "quantitative",
      "title": "Distinct Hospitality Venues"
    },

    "tooltip": [
      {"field": "Suburb"},
      {"field": "Income"},
      {"field": "Cafes"}
    ]
  }
}
