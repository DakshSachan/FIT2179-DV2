{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "Income-Table 1.csv"
  },

  "width": 700,
  "height": 350,

  "title": "Median Household Income by Melbourne Postcode",

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 80
    },
    "strokeWidth": 3,
    "color": "#6F4E37"
  },

  "encoding": {

    "x": {
      "field": "Postcode",
      "type": "ordinal",
      "title": "Postcode"
    },

    "y": {
      "field": "Household Weekly Income",
      "type": "quantitative",
      "title": "Median Household Weekly Income ($)"
    },

    "tooltip": [
      {
        "field": "Postcode",
        "title": "Postcode"
      },
      {
        "field": "Household Weekly Income",
        "title": "Household Income ($)"
      }
    ]
  }
}
